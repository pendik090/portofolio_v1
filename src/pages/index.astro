---
import Layout from "../layouts/Layouts.astro"
import Home from "../layouts/Home.astro"
import About from "../layouts/About.astro"
import Projects from "../layouts/Projects.astro"
import Statistics from "../layouts/Statistics.astro"
import ProjectDetails from "../layouts/ProjectDetails.astro"
import Header from "../components/Header.astro"
import Sidebar from "../components/Sidebar.astro"
---

<Layout
	title="Rosfendik — Full Stack Developer"
	description="Rosfendik — Full Stack Developer based in Surabaya, Indonesia. Experienced in Laravel, Flutter, and TailwindCSS. Explore my projects and experience."
	activeSection="home"
>
	<!-- Overlay for mobile sidebar -->
    <div class="overlay hidden fixed inset-0 bg-black/50 z-95 backdrop-blur-sm" id="overlay"></div>

    <Header></Header>

    <Sidebar activeSection="home"></Sidebar>

    <!-- Main Content -->
    <main class="ml-sidebar min-h-screen px-10 py-8 max-md:ml-0 max-md:px-5 max-md:pt-19 max-sm:px-4 max-sm:pt-18">
        <Home active={true}></Home>

        <About></About>

        <Projects></Projects>

        <Statistics></Statistics>

        <ProjectDetails></ProjectDetails>
    </main>
	
</Layout>