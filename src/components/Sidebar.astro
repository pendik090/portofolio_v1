---
const { activeSection = 'home' } = Astro.props;
---
<!-- Sidebar -->
    <aside class="sidebar fixed top-0 left-0 w-sidebar max-md:w-[85vw] max-md:max-w-sidebar h-screen bg-dark-primary flex flex-col z-100 transition-transform duration-300 ease-in-out" id="sidebar">
        <div class="px-7 pt-9 pb-7 text-center max-sm:px-4 max-sm:pt-6 max-sm:pb-4">
            <div class="w-32 h-32 max-sm:w-22.5 max-sm:h-22.5 rounded-full mx-auto mb-5 overflow-hidden border-2 border-accent p-0.75 bg-dark-primary">
                <img src="/assets/img/profile4.jpeg" alt="Profile Photo" class="w-full h-full rounded-full object-cover">
            </div>
            <h2 class="text-2xl font-semibold mb-1">Rosfendik</h2>
            <p class="text-md text-accent font-medium mb-2">Full Stack Developer</p>
            <p class="text-md text-gray-500 flex items-center justify-center gap-1.5 mb-5">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                Based in Surabaya, Indonesia
            </p>
            <div class="flex justify-center gap-3">
                <a href="https://github.com/pendik090" title="GitHub" aria-label="GitHub" class="w-11 h-11 rounded-lg bg-dark-card border border-border flex items-center justify-center text-gray-400 hover:text-accent hover:border-accent hover:bg-accent-subtle transition-all duration-300">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                </a>
                <a href="mailto:rospendik321@gmail.com" title="Email" aria-label="Email" class="w-11 h-11 rounded-lg bg-dark-card border border-border flex items-center justify-center text-gray-400 hover:text-accent hover:border-accent hover:bg-accent-subtle transition-all duration-300">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                </a>
                <a href="https://www.linkedin.com/in/ros-fendik-ba4998208" title="Linkedin" aria-label="Linkedin" class="w-11 h-11 rounded-lg bg-dark-card border border-border flex items-center justify-center text-gray-400 hover:text-accent hover:border-accent hover:bg-accent-subtle transition-all duration-300">
                    <!-- linkedin icon -->
                    <i class="devicon-linkedin-plain h-11 w-11 flex items-center justify-center"></i>
                </a>
                <a href="/rosfendik_cv.pdf" download title="Download CV" aria-label="Download CV" class="w-11 h-11 rounded-lg bg-dark-card border border-border flex items-center justify-center text-gray-400 hover:text-accent hover:border-accent hover:bg-accent-subtle transition-all duration-300">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                </a>
            </div>
        </div>
        <hr class="w-80 border-t border-border mt-5 mx-auto">
        <nav class="flex-1 mt-12 max-sm:px-3 flex flex-col justify-start gap-1.5 max-w-90">
            <a href="/" class={`nav-link ${activeSection === 'home' ? 'active' : ''} flex items-center gap-3.5 px-8 py-3.5 rounded-lg text-gray-400 text-[1.25rem] font-normal transition-all duration-300 cursor-pointer hover:text-gray-200 hover:bg-dark-card`} data-section="home">
                <svg class="shrink-0" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                <span>Home</span>
            </a>
            <a href="/about" class={`nav-link ${activeSection === 'about' ? 'active' : ''} flex items-center gap-3.5 px-8 py-3.5 rounded-lg text-gray-400 text-[1.25rem] font-normal transition-all duration-300 cursor-pointer hover:text-gray-200 hover:bg-dark-card`} data-section="about">
                <svg class="shrink-0" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                <span>About Me</span>
            </a>
            <a href="/projects" class={`nav-link ${activeSection === 'projects' ? 'active' : ''} flex items-center gap-3.5 px-8 py-3.5 rounded-lg text-gray-400 text-[1.25rem] font-normal transition-all duration-300 cursor-pointer hover:text-gray-200 hover:bg-dark-card`} data-section="projects">
                <svg class="shrink-0" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
                <span>Projects</span>
            </a>
            <!-- <a href="/statistics" class="nav-link flex items-center gap-3.5 px-8 py-3.5 rounded-lg text-gray-400 text-[1.25rem] font-normal transition-all duration-300 cursor-pointer hover:text-gray-200 hover:bg-dark-card" data-section="statistics">
                <svg class="shrink-0" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 20V10"/><path d="M12 20V4"/><path d="M6 20v-6"/></svg>
                <span>Statistics</span>
            </a> -->
        </nav>
        <div class="px-7 py-5 max-sm:px-4 max-sm:py-3 border-t border-border text-center">
            <p class="text-lg max-sm:text-sm text-gray-500">COPYRIGHT &copy; 2026</p>
            <p class="text-lg max-sm:text-sm text-gray-500">ROSFENDIK. All Rights Reserved.</p>
        </div>
    </aside>