---
import "../css/global.css";
import "../css/style.css";
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="stylesheet" href="https://cloudflare.com">
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
		<link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/devicon.min.css">
		<!-- favicon -->
		<link rel="icon" type="image/jpg" href="/assets/img/favicon.jpg">
		<!-- Canonical URL -->
		<link rel="canonical" href="https://rosfendik.dev/">
		<!-- Sitemap reference -->
		<link rel="sitemap" type="application/xml" href="/sitemap.xml">
		<!-- Meta SEO -->
		<meta name="description" content="Rosfendik — Full Stack Developer based in Surabaya, Indonesia. Experienced in Laravel, Flutter, and TailwindCSS. Explore my projects and experience.">
		<meta name="keywords" content="Rosfendik, Full Stack Developer, Laravel, Flutter, TailwindCSS, Web Developer, Surabaya">
		<meta name="author" content="Rosfendik">
		<!-- Open Graph -->
		<meta property="og:title" content="Rosfendik — Full Stack Developer">
		<meta property="og:description" content="Full Stack Developer based in Surabaya. Building efficient, scalable, and maintainable web applications.">
		<meta property="og:type" content="website">
		<meta property="og:url" content="https://rosfendik.dev/">
		<title>Rosfendik</title>
	</head>
	<body class="font-inter bg-dark-primary text-gray-200 leading-relaxed overflow-x-hidden">
		<slot>

        </slot>
		<script src="https://cdn.jsdelivr.net/npm/mixitup/dist/mixitup.min.js"></script>
        <script>
            import "../js/script.js";
        </script>
	</body>
</html>
