---
import "../css/global.css";
import "../css/style.css";

interface Props {
	title?: string;
	description?: string;
	canonical?: string;
	ogTitle?: string;
	ogDescription?: string;
	activeSection?: string;
}

const {
	title = 'Rosfendik — Full Stack Developer',
	description = 'Rosfendik — Full Stack Developer based in Surabaya, Indonesia. Experienced in Laravel, Flutter, and TailwindCSS. Explore my projects and experience.',
	canonical,
	ogTitle = 'Rosfendik — Full Stack Developer',
	ogDescription = 'Full Stack Developer based in Surabaya. Building efficient, scalable, and maintainable web applications.',
	activeSection = 'home',
} = Astro.props;

const canonicalURL = canonical || new URL(Astro.url.pathname, Astro.site).href;
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="stylesheet" href="https://cloudflare.com">
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
		<link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/devicon.min.css">
		<!-- favicon -->
		<link rel="icon" type="image/jpg" href="/assets/img/favicon.jpg">
		<!-- Canonical URL -->
		<link rel="canonical" href={canonicalURL}>
		<!-- Sitemap reference -->
		<link rel="sitemap" type="application/xml" href="/sitemap.xml">
		<!-- Meta SEO -->
		<meta name="description" content={description}>
		<meta name="keywords" content="Rosfendik, Full Stack Developer, Laravel, Flutter, TailwindCSS, Web Developer, Surabaya">
		<meta name="author" content="Rosfendik">
		<!-- Open Graph -->
		<meta property="og:title" content={ogTitle}>
		<meta property="og:description" content={ogDescription}>
		<meta property="og:type" content="website">
		<meta property="og:url" content={canonicalURL}>
		<title>{title}</title>
	</head>
	<body class="font-inter bg-dark-primary text-gray-200 leading-relaxed overflow-x-hidden" data-active-section={activeSection}>
		<slot>

        </slot>
		<script src="https://cdn.jsdelivr.net/npm/mixitup/dist/mixitup.min.js"></script>
        <script>
            import "../js/script.js";
        </script>
	</body>
</html>
