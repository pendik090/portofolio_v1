---
const { active = false } = Astro.props;
---
        <!-- ====== ABOUT ====== -->
        <section class={`content-section ${active ? 'active' : 'hidden'} animate-fadeIn px-4`} id="about">
            <!-- Description -->
            <div class="mb-10">
                <h1 class="flex items-center gap-2.5 text-[1.75rem] font-semibold mb-5 text-gray-200 max-sm:text-lg">
                    <svg class="text-accent" width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                    About Me
                </h1>
                <div class="bg-dark-card border border-border rounded-xl px-7 py-6 max-sm:px-4 max-sm:py-4">
                    <p class="text-gray-400 text-[1.25rem] max-sm:text-base leading-7 text-justify mb-4">Hi! I'm <strong class="text-gray-200">Rosfendik</strong>, a passionate Full Stack Developer based in <strong class="text-gray-200">Surabaya, Indonesia</strong>. I have over 1 year of experience building web applications with modern technologies such as Laravel, Flutter, and Tailwindcss.</p>
                    <p class="text-gray-400 text-[1.25rem] max-sm:text-base leading-7 text-justify mb-4">I specialize in creating clean, performant, and scalable solutions — from responsive front-end interfaces to robust back-end architectures. I'm dedicated to writing maintainable code and continuously learning new technologies to deliver the best results.</p>
                </div>
            </div>

            <!-- Career Experience Timeline -->
            <div class="mb-10">
                <h2 class="flex items-center gap-2.5 text-[1.5rem] max-sm:text-lg font-semibold mb-5 text-gray-200">
                    <svg class="text-accent" width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
                    Career Experience
                </h2>
                <div class="timeline relative pl-8">
                    <!-- Item 1 -->
                    <div class="timeline-item relative mb-6">
                        <div class="timeline-dot"></div>
                        <div class="bg-dark-card border border-border rounded-xl overflow-hidden transition-colors duration-300 hover:border-accent">
                            <button class="career-toggle w-full text-left px-6 py-5 flex items-start gap-4" aria-expanded="false">
                                <!-- Company Logo -->
                                <div class="shrink-0 w-32 h-32   flex items-center justify-center overflow-hidden mt-0.5">
                                    <img src="/assets/img/logo_cm.jpg" alt="Company Logo" class="w-full h-full object-contain p-1.5" onload="this.style.display='block';this.parentElement.querySelector('.logo-fallback').style.display='none'" style="display:none">
                                    <div class="logo-fallback w-full h-full flex items-center justify-center text-gray-600">
                                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
                                    </div>
                                </div>
                                <div class="flex-1 min-w-0">
                                    <div class="flex flex-wrap items-center gap-4 mb-1">
                                        <h3 class="text-[1.15rem] font-semibold text-gray-100">Full Stack Developer</h3>
                                        <span class="text-sm text-accent font-medium whitespace-nowrap px-2.5 py-0.5 bg-accent-subtle rounded-full">May 2025 — Present</span>
                                    </div>
                                    <p class="text-md text-gray-500 font-medium leading-6 mb-1">Creative Media •  Surabaya, Indonesia</p>
                                    <p class="text-md text-gray-500 font-medium leading-6">Onsite • Employee</p>
                                </div>
                                <div class="shrink-0 flex flex-row items-center gap-1">
                                    <span class="career-toggle-label text-md text-gray-500 font-medium tracking-wide">Show Details</span><svg class="career-chevron text-gray-500 transition-transform duration-300" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
                                </div>
                            </button>
                            <div class="career-details hidden px-6 pb-5 border-t border-border">
                                <p class="text-[1.05rem] text-gray-400 leading-7 mt-4 mb-4"> Responsible for 4 web-based projects owned by clients and internal companies as a full stack developer including ensuring system optimization, database backups, and fixing errors. Also fulfill requirement as a course trainer in urgent circumstances.</p>
                                <ul class="flex flex-col gap-2">
                                    <li class="flex items-start gap-2.5 text-md text-gray-400">
                                        <span class="shrink-0 w-1.5 h-1.5 rounded-full bg-accent mt-2"></span> Develop, deploy and maintain client-owned and internal company web-based applications to ensure optimal performance and user experience.
                                    </li>
                                    <li class="flex items-center gap-2.5 text-md text-gray-400">
                                        <span class="shrink-0 w-1.5 h-1.5 rounded-full bg-accent"></span> Perform media and database backups from servers for client and internal company applications on a regular schedule.
                                    </li>
                                    <li class="flex items-center gap-2.5 text-md text-gray-400">
                                        <span class="shrink-0 w-1.5 h-1.5 rounded-full bg-accent"></span> Teaching and mentoring students for programming courses at the basic level using python programming language
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>
                    <!-- Item 2 -->
                    <div class="timeline-item relative mb-6">
                        <div class="timeline-dot"></div>
                        <div class="bg-dark-card border border-border rounded-xl overflow-hidden transition-colors duration-300 hover:border-accent">
                            <button class="career-toggle w-full text-left px-6 py-5 flex items-start gap-4" aria-expanded="false">
                                <!-- Company Logo -->
                                <div class="shrink-0 w-32 h-32 flex items-center justify-center overflow-hidden mt-0.5">
                                    <img src="/assets/img/javadwipa_logo.jpg" alt="Company Logo" class="w-full h-full object-contain p-1.5" onload="this.style.display='block';this.parentElement.querySelector('.logo-fallback').style.display='none'" style="display:none">
                                    <div class="logo-fallback w-full h-full flex items-center justify-center text-gray-600">
                                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
                                    </div>
                                </div>
                                <div class="flex-1 min-w-0">
                                    <div class="flex flex-wrap items-center gap-4 mb-1">
                                        <h3 class="text-[1.15rem] font-semibold text-gray-100">Full Stack Developer</h3>
                                        <span class="text-sm text-accent font-medium whitespace-nowrap px-2.5 py-0.5 bg-accent-subtle rounded-full">Oct 2024 — May 2025</span>
                                    </div>
                                    <p class="text-md text-gray-500 font-medium leading-6 mb-1">PT Javadwipa Duta Mandiri •  Surabaya, Indonesia</p>
                                    <p class="text-md text-gray-500 font-medium leading-6">Onsite • Internship</p>
                                </div>
                                <div class="shrink-0 flex flex-row items-center gap-1">
                                    <span class="career-toggle-label text-md text-gray-500 font-medium tracking-wide">Show Details</span><svg class="career-chevron text-gray-500 transition-transform duration-300" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
                                </div>
                            </button>
                            <div class="career-details hidden px-6 pb-5 border-t border-border">
                                <p class="text-[1.05rem] text-gray-400 leading-7 mt-4 mb-4">Assisting the research and development process of web and mobile-based applications for internal company and client needs</p>
                                <ul class="flex flex-col gap-2">
                                    <li class="flex items-center gap-2.5 text-md text-gray-400">
                                        <span class="shrink-0 w-1.5 h-1.5 rounded-full bg-accent"></span> Contribute to develop the web based HSE division's document information as a full stack developer using Laravel.
                                    </li>
                                    <li class="flex items-center gap-2.5 text-md text-gray-400">
                                        <span class="shrink-0 w-1.5 h-1.5 rounded-full bg-accent"></span> Helps to improve the mobile apps for cctv monitoring system using Flutter and MQTT Protocol with teams.
                                    </li>
                                    <li class="flex items-center gap-2.5 text-md text-gray-400">
                                        <span class="shrink-0 w-1.5 h-1.5 rounded-full bg-accent"></span> Create an intuitive and interactive UI design for the visitor management system using figma.
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>
                    <!-- Item 3 -->
                    <div class="timeline-item relative mb-6">
                        <div class="timeline-dot"></div>
                        <div class="bg-dark-card border border-border rounded-xl overflow-hidden transition-colors duration-300 hover:border-accent">
                            <button class="career-toggle w-full text-left px-6 py-5 flex items-start gap-4" aria-expanded="false">
                                <!-- Company Logo -->
                                <div class="shrink-0 w-32 h-32 flex items-center justify-center overflow-hidden mt-0.5">
                                    <img src="/assets/img/solusimaster_logo.jpg" alt="Company Logo" class="w-full h-full object-contain p-1.5" onload="this.style.display='block';this.parentElement.querySelector('.logo-fallback').style.display='none'" style="display:none">
                                    <div class="logo-fallback w-full h-full flex items-center justify-center text-gray-600">
                                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
                                    </div>
                                </div>
                                <div class="flex-1 min-w-0">
                                    <div class="flex flex-wrap items-center gap-4 mb-1">
                                        <h3 class="text-[1.15rem] font-semibold text-gray-100">Full Stack Developer</h3>
                                        <span class="text-sm text-accent font-medium whitespace-nowrap px-2.5 py-0.5 bg-accent-subtle rounded-full">Dec 2023 — Feb 2024</span>
                                    </div>
                                    <p class="text-md text-gray-500 font-medium leading-6 mb-1">PT Digital Solusi Master •  Sidoarjo, Indonesia</p>
                                    <p class="text-md text-gray-500 font-medium leading-6">Onsite • Internship</p>
                                </div>
                                <div class="shrink-0 flex flex-row items-center gap-1">
                                    <span class="career-toggle-label text-md text-gray-500 font-medium tracking-wide">Show Details</span><svg class="career-chevron text-gray-500 transition-transform duration-300" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
                                </div>
                            </button>
                            <div class="career-details hidden px-6 pb-5 border-t border-border">
                                <p class="text-[1.05rem] text-gray-400 leading-7 mt-4 mb-4">Contribute to developing a website-based school information system and lerning to inderstood of product development in corporate settings</p>
                                <ul class="flex flex-col gap-2">
                                    <li class="flex items-center gap-2.5 text-md text-gray-400">
                                        <span class="shrink-0 w-1.5 h-1.5 rounded-full bg-accent"></span>Contribute to develop website based application as full stack developer using Laravel with teams
                                    </li>
                                    <li class="flex items-center gap-2.5 text-md text-gray-400">
                                        <span class="shrink-0 w-1.5 h-1.5 rounded-full bg-accent"></span> Improve database query skills to ensure performance and optimization using SQL Database.
                                    </li>
                                    <li class="flex items-center gap-2.5 text-md text-gray-400">
                                        <span class="shrink-0 w-1.5 h-1.5 rounded-full bg-accent"></span>Help to communicate and established good relationship with clients to developed application.
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>
                    <!-- Item 4 -->
                    <div class="timeline-item relative">
                        <div class="timeline-dot"></div>
                        <div class="bg-dark-card border border-border rounded-xl overflow-hidden transition-colors duration-300 hover:border-accent">
                            <button class="career-toggle w-full text-left px-6 py-5 flex items-start gap-4" aria-expanded="false">
                                <!-- Company Logo -->
                                <div class="shrink-0 w-32 h-32 rounded-xl border border-border bg-dark-secondary flex items-center justify-center overflow-hidden mt-0.5">
                                    <img src="" alt="Company Logo" class="w-full h-full object-contain p-1.5" onload="this.style.display='block';this.parentElement.querySelector('.logo-fallback').style.display='none'" style="display:none">
                                    <div class="logo-fallback w-full h-full flex items-center justify-center text-gray-600">
                                        <svg width="42" height="42" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
                                    </div>
                                </div>
                                <div class="flex-1 min-w-0">
                                    <div class="flex flex-wrap items-center gap-4 mb-1">
                                        <h3 class="text-[1.15rem] font-semibold text-gray-100">Field Engineer</h3>
                                        <span class="text-sm text-accent font-medium whitespace-nowrap px-2.5 py-0.5 bg-accent-subtle rounded-full">July 2018 — Aug 2020</span>
                                    </div>
                                    <p class="text-md leading-6 text-gray-500 font-medium mb-1">PT Dwitunggal Jaya Abadi • Sidoarjo, Indonesia</p>
                                    <p class="text-md leading-6 text-gray-500 font-medium">Onsite • Employee</p>
                                </div>
                                <div class="shrink-0 flex flex-row items-center gap-1">
                                    <span class="career-toggle-label text-md text-gray-500 font-medium tracking-wide">Show Details</span><svg class="career-chevron text-gray-500 transition-transform duration-300" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
                                </div>
                            </button>
                            <div class="career-details hidden px-6 pb-5 border-t border-border">
                                <p class="text-[1.05rem] text-gray-400 leading-7 mt-4 mb-4">Responsible for maintaining and ensuring the automatic meter reading device works properly and can be read in real time</p>
                                <ul class="flex flex-col gap-2">
                                    <li class="flex items-center gap-2.5 text-md text-gray-400">
                                        <span class="shrink-0 w-1.5 h-1.5 rounded-full bg-accent"></span>Resolve problems with IoT based Automatic Meter Reading tools in partnership with PT PLN Persero.
                                    </li>
                                    <li class="flex items-center gap-2.5 text-md text-gray-400">
                                        <span class="shrink-0 w-1.5 h-1.5 rounded-full bg-accent"></span>Ensure the automatic meter reading device can be read via monitoring website.
                                    </li>
                                    <li class="flex items-center gap-2.5 text-md text-gray-400">
                                        <span class="shrink-0 w-1.5 h-1.5 rounded-full bg-accent"></span>Provide understanding to customers regarding to the works and create a daily report.
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Education -->
            <div class="mb-10">
                <h2 class="flex items-center gap-2.5 text-xl font-semibold mb-5 text-gray-200 max-sm:text-lg">
                    <svg class="text-accent" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c0 1 4 3 6 3s6-2 6-3v-5"/></svg>
                    Education
                </h2>
                <div class="grid grid-cols-[repeat(auto-fill,minmax(340px,1fr))] gap-5 max-md:grid-cols-1">
                    <div class="bg-dark-card border border-border rounded-xl p-6 max-sm:p-4 transition-all duration-300 hover:border-accent hover:-translate-y-0.5">
                        <div class="w-36 h-36 max-sm:w-20 max-sm:h-20 flex items-center justify-center overflow-hidden mb-4">
                            <img src="/assets/img/untag.png" alt="Institution Logo" class="w-full h-full object-contain p-2" onload="this.style.display='block';this.parentElement.querySelector('.logo-fallback').style.display='none'" style="display:none">
                            <div class="logo-fallback w-full h-full flex items-center justify-center text-gray-600">
                                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c0 1 4 3 6 3s6-2 6-3v-5"/></svg>
                            </div>
                        </div>
                        <h3 class="text-lg font-semibold mb-1">S1 — Teknik Informatika</h3>
                        <p class="text-md text-gray-400 mb-0.5">Universitas 17 Agustus 1945 Surabaya</p>
                        <p class="text-md text-gray-500 mb-1.5">2020 — 2024</p>
                        <p class="text-md text-accent font-medium">GPA: 3.66 / 4.00</p>
                    </div>
                    <div class="bg-dark-card border border-border rounded-xl p-6 max-sm:p-4 transition-all duration-300 hover:border-accent hover:-translate-y-0.5">
                        <div class="w-36 h-36 max-sm:w-20 max-sm:h-20 flex items-center justify-center overflow-hidden mb-4">
                            <img src="/assets/img/smk7.png" alt="Institution Logo" class="w-full h-full object-contain p-2" onload="this.style.display='block';this.parentElement.querySelector('.logo-fallback').style.display='none'" style="display:none">
                            <div class="logo-fallback w-full h-full flex items-center justify-center text-gray-600">
                                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/></svg>
                            </div>
                        </div>
                        <h3 class="text-lg font-semibold mb-1">Mechanical Engineering</h3>
                        <p class="text-md text-gray-400 mb-0.5">SMK Negeri 7 Surabaya</p>
                        <p class="text-md text-gray-500 mb-1.5">2018</p>
                    </div>
                </div>
            </div>
        </section>